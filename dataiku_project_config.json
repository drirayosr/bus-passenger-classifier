{
  "projectKey": "BUS_PASSENGER_CLASSIFIER",
  "projectName": "Bus Passenger Classifier",
  "description": "ML system for classifying and predicting bus passenger loads using HDBSCAN clustering and ensemble models",
  "shortDesc": "Automated bus passenger prediction system",
  "imgColor": "#3498db",
  "tags": ["machine-learning", "transportation", "clustering", "ensemble-learning"],
  "checklists": {
    "checklists": []
  },
  "datasets": [
    {
      "name": "passengers",
      "type": "UploadedFiles",
      "managed": true,
      "formatType": "csv",
      "schema": {
        "columns": [
          {"name": "vehicle_id", "type": "string"},
          {"name": "platform", "type": "string"},
          {"name": "lat", "type": "double"},
          {"name": "lon", "type": "double"},
          {"name": "timestamp_utc", "type": "date"},
          {"name": "tz", "type": "string"},
          {"name": "local_time", "type": "date"},
          {"name": "state", "type": "string"},
          {"name": "mode", "type": "string"},
          {"name": "mileage", "type": "int"},
          {"name": "speed", "type": "double"},
          {"name": "outside_temperature", "type": "int"},
          {"name": "inside_temperature", "type": "int"},
          {"name": "payload", "type": "int"},
          {"name": "battery_level", "type": "double"},
          {"name": "door_state", "type": "string"},
          {"name": "ramp_state", "type": "string"}
        ]
      }
    },
    {
      "name": "buses",
      "type": "UploadedFiles",
      "managed": true,
      "formatType": "csv",
      "schema": {
        "columns": [
          {"name": "vehicle_id", "type": "string"},
          {"name": "platform", "type": "string"},
          {"name": "state", "type": "string"},
          {"name": "lat", "type": "double"},
          {"name": "lon", "type": "double"},
          {"name": "utc_time", "type": "date"},
          {"name": "mode", "type": "string"},
          {"name": "mileage", "type": "int"},
          {"name": "speed", "type": "double"},
          {"name": "outside_temperature", "type": "int"},
          {"name": "inside_temperature", "type": "int"},
          {"name": "payload", "type": "int"},
          {"name": "battery_level", "type": "double"},
          {"name": "door_state", "type": "string"},
          {"name": "ramp_state", "type": "string"}
        ]
      }
    }
  ],
  "flow": {
    "zones": [
      {
        "name": "Data Ingestion",
        "color": "#2ecc71",
        "items": ["passengers", "buses"]
      },
      {
        "name": "Data Preparation",
        "color": "#3498db",
        "items": ["merged_data", "clean_data", "engineered_features"]
      },
      {
        "name": "Model Training",
        "color": "#9b59b6",
        "items": ["trained_model", "model_evaluation"]
      },
      {
        "name": "Deployment",
        "color": "#e74c3c",
        "items": ["api_endpoint", "predictions"]
      }
    ]
  },
  "scenarios": [
    {
      "name": "Weekly Model Retraining",
      "type": "step_based",
      "active": true,
      "triggers": [
        {
          "type": "temporal",
          "frequencyMode": "WEEKLY",
          "daysOfWeek": ["SUNDAY"],
          "hour": 2,
          "minute": 0
        }
      ],
      "steps": [
        {
          "type": "build_dataset",
          "params": {
            "dataset": "merged_data"
          }
        },
        {
          "type": "build_dataset",
          "params": {
            "dataset": "clean_data"
          }
        },
        {
          "type": "build_dataset",
          "params": {
            "dataset": "engineered_features"
          }
        },
        {
          "type": "train_model",
          "params": {
            "model": "bus_classifier"
          }
        },
        {
          "type": "evaluate_model",
          "params": {
            "model": "bus_classifier",
            "testDataset": "engineered_features"
          }
        },
        {
          "type": "deploy_to_api",
          "params": {
            "model": "bus_classifier",
            "apiEndpoint": "bus_prediction_api"
          }
        }
      ],
      "reporter": {
        "sendOnSuccess": true,
        "sendOnFailure": true,
        "sendOnAbort": true
      }
    },
    {
      "name": "Daily Batch Predictions",
      "type": "step_based",
      "active": true,
      "triggers": [
        {
          "type": "temporal",
          "frequencyMode": "DAILY",
          "hour": 6,
          "minute": 0
        }
      ],
      "steps": [
        {
          "type": "build_dataset",
          "params": {
            "dataset": "new_passengers"
          }
        },
        {
          "type": "run_prediction",
          "params": {
            "model": "bus_classifier",
            "inputDataset": "new_passengers",
            "outputDataset": "batch_predictions"
          }
        }
      ]
    },
    {
      "name": "Model Performance Monitoring",
      "type": "step_based",
      "active": true,
      "triggers": [
        {
          "type": "temporal",
          "frequencyMode": "HOURLY",
          "hour": null,
          "everyNHours": 6
        }
      ],
      "steps": [
        {
          "type": "evaluate_model",
          "params": {
            "model": "bus_classifier",
            "testDataset": "clean_data"
          }
        },
        {
          "type": "check_metric",
          "params": {
            "metric": "accuracy",
            "threshold": 0.75,
            "alertOnFailure": true
          }
        }
      ]
    }
  ],
  "recipes": [
    {
      "name": "join_passenger_bus_data",
      "type": "join",
      "inputs": ["passengers", "buses"],
      "outputs": ["merged_data"],
      "params": {
        "joinType": "LEFT",
        "on": [
          {"left": "vehicle_id", "right": "vehicle_id"},
          {"left": "timestamp_utc", "right": "utc_time"}
        ]
      }
    },
    {
      "name": "prepare_clean_data",
      "type": "prepare",
      "inputs": ["merged_data"],
      "outputs": ["clean_data"],
      "steps": [
        {"type": "RemoveRowsOnEmpty", "columns": ["vehicle_id", "payload"]},
        {"type": "FilterOnValue", "column": "speed", "filterType": ">=", "value": 0},
        {"type": "FilterOnValue", "column": "payload", "filterType": ">=", "value": 0},
        {"type": "FillEmptyWithValue", "column": "battery_level", "value": 50}
      ]
    },
    {
      "name": "engineer_features",
      "type": "prepare",
      "inputs": ["clean_data"],
      "outputs": ["engineered_features"],
      "steps": [
        {"type": "ExtractFromDate", "column": "timestamp_utc", "extract": "HOUR", "output": "hour"},
        {"type": "ExtractFromDate", "column": "timestamp_utc", "extract": "DAY_OF_WEEK", "output": "day_of_week"},
        {"type": "ExtractFromDate", "column": "timestamp_utc", "extract": "MONTH", "output": "month"},
        {"type": "CreateColumnWithFormula", "output": "is_weekend", "formula": "day_of_week >= 5"},
        {"type": "CreateColumnWithFormula", "output": "is_rush_hour", "formula": "(hour >= 7 && hour <= 9) || (hour >= 16 && hour <= 18)"},
        {"type": "CreateColumnWithFormula", "output": "temp_diff", "formula": "inside_temperature - outside_temperature"}
      ]
    }
  ],
  "models": [
    {
      "name": "bus_classifier",
      "type": "PREDICTION",
      "algorithm": "RANDOM_FOREST",
      "targetVariable": "label",
      "features": [
        "hour", "day_of_week", "month", "is_weekend", "is_rush_hour",
        "speed", "payload", "battery_level", "temp_diff",
        "outside_temperature", "inside_temperature"
      ],
      "split": {
        "method": "RANDOM",
        "trainRatio": 0.8,
        "testRatio": 0.2
      },
      "metrics": ["ACCURACY", "PRECISION", "RECALL", "F1"],
      "autoML": {
        "enabled": true,
        "algorithms": ["RANDOM_FOREST", "GRADIENT_BOOSTED_TREES", "LOGISTIC_REGRESSION", "XGBOOST"],
        "metric": "ACCURACY"
      }
    }
  ],
  "apiServices": [
    {
      "name": "bus_prediction_api",
      "type": "STANDARD",
      "endpoints": [
        {
          "name": "predict",
          "model": "bus_classifier",
          "method": "POST",
          "path": "/predict"
        },
        {
          "name": "health",
          "method": "GET",
          "path": "/health"
        }
      ]
    }
  ],
  "dashboards": [
    {
      "name": "Bus Passenger Analytics",
      "pages": [
        {
          "name": "Overview",
          "widgets": [
            {
              "type": "METRIC",
              "title": "Total Passengers Today",
              "dataset": "clean_data"
            },
            {
              "type": "CHART",
              "title": "Passenger Load by Hour",
              "chartType": "LINE",
              "xAxis": "hour",
              "yAxis": "payload"
            },
            {
              "type": "MAP",
              "title": "Bus Locations",
              "latColumn": "lat",
              "lonColumn": "lon"
            }
          ]
        },
        {
          "name": "Model Performance",
          "widgets": [
            {
              "type": "METRIC",
              "title": "Model Accuracy",
              "model": "bus_classifier",
              "metric": "ACCURACY"
            },
            {
              "type": "CHART",
              "title": "Confusion Matrix",
              "chartType": "HEATMAP",
              "model": "bus_classifier"
            }
          ]
        }
      ]
    }
  ]
}
